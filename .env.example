# dev | stage | prod
ENV=dev

# Для Docker Compose: DB__HOST=db
# Для локальной разработки: DB__HOST=localhost
DB__HOST=db
DB__PORT=5432
DB__USER=postgres
DB__PASSWORD=postgres
DB__NAME=lib_management

# Опционально. Если не задано, echo=True в dev, echo=False в prod/stage.
# DB__ECHO=true
DB__POOL_SIZE=20
DB__MAX_OVERFLOW=10
DB__POOL_RECYCLE=1800

# ── LLM-провайдер ────────────────────────────────────────
# Доступные: gemini (по умолчанию), ollama
# LLM__PROVIDER=gemini
# Для gemini обязателен, для ollama — опционален
LLM__API_KEY=your-api-key-here
# Для ollama
# LLM__OLLAMA_HOST=http://localhost:11434

# Модели (значения по умолчанию)
# LLM__MODEL_NAME=gemini-2.5-flash
# LLM__EMBEDDING_MODEL=gemini-embedding-001
# Пример для ollama:
# LLM__MODEL_NAME=qwen2.5:7b
# LLM__EMBEDDING_MODEL=bge-m3:latest
# LLM__EMBEDDING_DIM=768
# LLM__MAX_TOKEN_SIZE=8192

# Чанкинг
# LLM__CHUNK_TOKEN_SIZE=1200
# LLM__CHUNK_OVERLAP_TOKEN_SIZE=100
# LLM__WORKSPACE=default

# Rate limiting (скользящее окно)
# LLM__LLM_RATE_LIMIT=15
# LLM__EMBED_RATE_LIMIT=80
# LLM__RATE_LIMIT_WINDOW=60.0

# Retry при 429 / RESOURCE_EXHAUSTED
# LLM__MAX_RETRIES=5
# LLM__LLM_RETRY_BASE_DELAY=15.0
# LLM__LLM_RETRY_MAX_DELAY=90.0
# LLM__EMBED_RETRY_BASE_DELAY=30.0
# LLM__EMBED_RETRY_MAX_DELAY=120.0

# ── Graph RAG storage ─────────────────────────────────────
# Опции: Neo4JStorage (рекомендуется), NetworkXStorage (локальный fallback)
RAG__GRAPH_STORAGE=Neo4JStorage

# ── Neo4j (граф знаний: entities + relationships) ────────
# Для Docker Compose по умолчанию host=neo4j
NEO4J__HOST=neo4j
NEO4J__PORT=7687
NEO4J__USER=neo4j
NEO4J__PASSWORD=neo4jpassword
NEO4J__DATABASE=neo4j
NEO4J__WORKSPACE=default

# ── Хранилище файлов ──────────────────────────────────────
# local  — файлы в папке проекта (uploads/), удобно для dev
# minio  — S3-совместимое хранилище (рекомендуется для prod)
STORAGE__MODE=minio
# Путь к папке при STORAGE__MODE=local (относительно корня проекта)
# STORAGE__LOCAL_PATH=uploads

# ── MinIO (объектное хранилище документов) ───────────────
# Используется при STORAGE__MODE=minio
# Для Docker Compose endpoint=minio:9000, для локального запуска — localhost:9000
MINIO__ENDPOINT=minio:9000
MINIO__ACCESS_KEY=minioadmin
MINIO__SECRET_KEY=minioadmin
MINIO__BUCKET_NAME=documents
MINIO__USE_SSL=false
