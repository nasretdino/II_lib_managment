# dev | stage | prod
ENV=dev

# Для Docker Compose: DB__HOST=db
# Для локальной разработки: DB__HOST=localhost
DB__HOST=db
DB__PORT=5432
DB__USER=postgres
DB__PASSWORD=postgres
DB__NAME=lib_management

# Опционально. Если не задано, echo=True в dev, echo=False в prod/stage.
# DB__ECHO=true
DB__POOL_SIZE=20
DB__MAX_OVERFLOW=10
DB__POOL_RECYCLE=1800

# ── LLM-провайдер ────────────────────────────────────────
# Доступные: gemini (по умолчанию)
# LLM__PROVIDER=gemini
LLM__API_KEY=your-api-key-here

# Модели (значения по умолчанию)
# LLM__MODEL_NAME=gemini-2.5-flash
# LLM__EMBEDDING_MODEL=gemini-embedding-001
# LLM__EMBEDDING_DIM=768
# LLM__MAX_TOKEN_SIZE=8192

# Чанкинг
# LLM__CHUNK_TOKEN_SIZE=1200
# LLM__CHUNK_OVERLAP_TOKEN_SIZE=100
# LLM__WORKSPACE=default

# Rate limiting (скользящее окно)
# LLM__LLM_RATE_LIMIT=15
# LLM__EMBED_RATE_LIMIT=80
# LLM__RATE_LIMIT_WINDOW=60.0

# Retry при 429 / RESOURCE_EXHAUSTED
# LLM__MAX_RETRIES=5
# LLM__LLM_RETRY_BASE_DELAY=15.0
# LLM__LLM_RETRY_MAX_DELAY=90.0
# LLM__EMBED_RETRY_BASE_DELAY=30.0
# LLM__EMBED_RETRY_MAX_DELAY=120.0
